APP_ENV=local
NODE_ENV=development
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:4100,http://127.0.0.1:4100,http://localhost:4101,http://127.0.0.1:4101,http://localhost:4102,http://127.0.0.1:4102

SUPABASE_PROJECT_NAME=clubline-local
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: used only by scripts/db/*.sh to apply and verify schema.
SUPABASE_DB_URL=

ENABLE_LOCAL_REALTIME_FALLBACK=true
ENABLE_LEGACY_WORKFLOW_FALLBACK=false
