# Generic backend environment template.
# Prefer copying one of the environment-specific templates from:
#   config/environments/backend/local.env.example
#   config/environments/backend/dev.env.example
#   config/environments/backend/prod.env.example
#
# Example:
#   cp config/environments/backend/local.env.example config/environments/backend/local.env.local
#   ./scripts/env/use-backend-env.sh local

APP_ENV=local
NODE_ENV=development
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SUPABASE_PROJECT_NAME=
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

ENABLE_LOCAL_REALTIME_FALLBACK=true
ENABLE_LEGACY_WORKFLOW_FALLBACK=false
