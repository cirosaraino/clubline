{
  "name": "clubline-backend",
  "private": true,
  "version": "1.0.0",
  "description": "REST backend for Clubline",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_ENV=test tsx --test src/**/*.test.ts",
    "validate:e2e:supabase": "tsx tests/e2e/production-supabase-validation.ts",
    "check": "npm run typecheck && npm test",
    "bootstrap": "../scripts/backend/install.sh",
    "db:migrate": "../scripts/backend/migrate.sh dev",
    "db:seed": "../scripts/backend/seed.sh dev",
    "db:reset": "../scripts/backend/reset-dev-db.sh dev",
    "rebuild": "../scripts/backend/rebuild-from-zero.sh dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^24.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
