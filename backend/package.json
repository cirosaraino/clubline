{
  "name": "clubline-backend",
  "private": true,
  "version": "1.0.0",
  "description": "REST backend for Clubline",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
